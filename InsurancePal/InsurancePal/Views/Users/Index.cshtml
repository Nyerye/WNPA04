@model IEnumerable<InsurancePal.Models.User>

<h1>Users</h1>

<table class="table">
    <thead>
        <tr>
            <th>Username</th>
            <th>Is Admin</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.IsAdmin</td>
            </tr>
        }
    </tbody>
</table>
