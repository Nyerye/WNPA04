@model InsurancePal.Models.HomeDashboardViewModel

@{
    ViewData["Title"] = "Home";
}

<h1 class="mb-4">Welcome to InsurancePal</h1>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Items</h5>
                <p class="card-text fs-3">@Model.TotalItems</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Total Value</h5>
                <p class="card-text fs-3">$@Model.TotalValue</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Rooms Covered</h5>
                <p class="card-text fs-3">@Model.UniqueRooms</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-secondary">
            <div class="card-body">
                <h5 class="card-title">Categories Used</h5>
                <p class="card-text fs-3">@Model.UniqueCategories</p>
            </div>
        </div>
    </div>

</div>

<p class="mt-4">
    <a asp-controller="Item" asp-action="Index" class="btn btn-primary btn-sm">View Your Items</a>
</p>
