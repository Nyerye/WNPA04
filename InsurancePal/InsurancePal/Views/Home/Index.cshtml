@model InsurancePal.Models.HomeDashboardViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">

    <h1 class="mb-4 fw-bold text-center">Welcome to InsurancePal</h1>

    <div class="row g-4">

        <!--Total Items-->
        <div class="col-md-3 col-sm-6">
            <div class="card shadow-sm border-0 text-white bg-primary rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Total Items</h5>
                    <p class="card-text display-6 fw-bold">@Model.TotalItems</p>
                </div>
            </div>
        </div>

        <!--Total Value-->
        <div class="col-md-3 col-sm-6">
            <div class="card shadow-sm border-0 text-white bg-success rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Total Value</h5>
                    <p class="card-text display-6 fw-bold">$@Model.TotalValue</p>
                </div>
            </div>
        </div>

        <!--Rooms Covered-->
        <div class="col-md-3 col-sm-6">
            <div class="card shadow-sm border-0 text-white bg-info rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Rooms Covered</h5>
                    <p class="card-text display-6 fw-bold">@Model.UniqueRooms</p>
                </div>
            </div>
        </div>

        <!--Categories Used-->
        <div class="col-md-3 col-sm-6">
            <div class="card shadow-sm border-0 text-white bg-secondary rounded-4">
                <div class="card-body text-center">
                    <h5 class="card-title fw-semibold">Categories Used</h5>
                    <p class="card-text display-6 fw-bold">@Model.UniqueCategories</p>
                </div>
            </div>
        </div>

    </div>

    <div class="text-center mt-5">
        <a asp-controller="Item" asp-action="Index" class="btn btn-primary btn-lg px-4">
            View Your Items
        </a>
    </div>

</div>
