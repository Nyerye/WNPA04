@model InsurancePal.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 420px; border-radius: 12px;">
        <h2 class="text-center mb-4">Login</h2>

        <form asp-action="Login" method="post">
            <input asp-for="ReturnUrl" type="hidden" />

            <!--Username block-->
            <div class="mb-3">
                <label asp-for="Username" class="form-label fw-semibold"></label>
                <input asp-for="Username" class="form-control form-control-lg" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <!--Password block-->
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control form-control-lg" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 mt-2">
                Login
            </button>
        </form>

        <div class="text-danger mt-3 text-center" asp-validation-summary="ModelOnly"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
