@model InsurancePal.Models.Item

@{
    ViewData["Title"] = "Create";
}

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-lg p-4 w-100" style="max-width: 650px; border-radius: 12px;">

        <h2 class="text-center mb-3">Create New Item</h2>
        <p class="text-center text-muted mb-4">Add a new item to your inventory</p>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!--Name-->
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control form-control-lg" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!--Category-->
            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-semibold"></label>
                <select asp-for="Category" class="form-select form-select-lg"
                        asp-items="@(new SelectList(ViewBag.Categories))"></select>
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <!--Room-->
            <div class="mb-3">
                <label asp-for="Room" class="form-label fw-semibold"></label>
                <select asp-for="Room" class="form-select form-select-lg"
                        asp-items="@(new SelectList(ViewBag.Rooms))"></select>
                <span asp-validation-for="Room" class="text-danger small"></span>
            </div>

            <!--Estimated Value-->
            <div class="mb-3">
                <label asp-for="EstimatedValue" class="form-label fw-semibold"></label>
                <input asp-for="EstimatedValue" class="form-control form-control-lg" />
                <span asp-validation-for="EstimatedValue" class="text-danger small"></span>
            </div>

            <!--Purchase Date-->
            <div class="mb-3">
                <label asp-for="purchasedDate" class="form-label fw-semibold"></label>
                <input asp-for="purchasedDate" class="form-control form-control-lg" />
                <span asp-validation-for="purchasedDate" class="text-danger small"></span>
            </div>

            <!--Description-->
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <input asp-for="Description" class="form-control form-control-lg" />
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!--Submit Button-->
            <button type="submit" class="btn btn-primary w-100 py-2 mt-2">
                Create Item
            </button>

        </form>

        <!--Back to List-->
        <div class="text-center mt-3">
            <a asp-action="Index" class="text-decoration-none fw-semibold">
                ← Back to List
            </a>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
