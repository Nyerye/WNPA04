@model IEnumerable<InsurancePal.Models.Item>

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Your Items</h1>

        <a asp-action="Create" class="btn btn-primary btn-lg px-4">
            + Create New
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Category)</th>
                    <th>@Html.DisplayNameFor(model => model.Room)</th>
                    <th>@Html.DisplayNameFor(model => model.EstimatedValue)</th>
                    <th>@Html.DisplayNameFor(model => model.purchasedDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Description)</th>
                    <th class="text-center" style="width: 240px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Category)</td>
                        <td>@Html.DisplayFor(modelItem => item.Room)</td>
                        <td>$@Html.DisplayFor(modelItem => item.EstimatedValue)</td>
                        <td>@Html.DisplayFor(modelItem => item.purchasedDate)</td>
                        <td>@Html.DisplayFor(modelItem => item.Description)</td>

                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Edit"
                                   asp-route-id="@item.ItemId"
                                   class="btn btn-secondary btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.ItemId"
                                   class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.ItemId"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </div>
                        </td>

                        
                        
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
